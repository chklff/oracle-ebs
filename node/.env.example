# ---------------------------------------------------------------------------
# EBS Invoice API Wrapper (Node) - configuration template
#
#   cp .env.example .env      # then edit .env with real values
#
# .env is gitignored; never commit it. Only this template is tracked.
# Required (service will not start without them):
#   CLIENT_SECRET, EBS_DB_USER, EBS_DB_PASSWORD, EBS_DB_CONNECT_STRING
# Everything else has a sensible default.
# ---------------------------------------------------------------------------

# --- HTTP server ---
# Bind to loopback by default; restrict exposure at the network layer.
HOST=127.0.0.1
PORT=3000
# Log level: trace|debug|info|warn|error|fatal|silent
LOG_LEVEL=info
# Log format: pretty (human-readable, default) or json (for log aggregators)
LOG_FORMAT=pretty

# --- Shared secret required on every request (X-Client-Secret header) ---
# Generate a strong value, e.g.:  openssl rand -hex 32
CLIENT_SECRET=change-me-to-a-long-random-string

# --- Oracle EBS database connection (oracledb Thin mode; no Instant Client) ---
# Use the dedicated low-privilege account from docs/db-grants.sql, never APPS/DBA.
EBS_DB_USER=make_ap_svc
EBS_DB_PASSWORD=change-me
# Easy Connect string: host:port/service_name  (ask your DBA for the service name;
# it is the DB service, e.g. EBSPDB or PROD, not the EBS application URL).
EBS_DB_CONNECT_STRING=ebs-db-host:1521/EBSPDB

# Driver mode. Thin (default) needs no Oracle client install. Set EBS_DB_THICK=true
# only if the database enforces Native Network Encryption (connection fails with
# ORA-12660 / NJS-533 in Thin mode). Thick mode requires Oracle Instant Client on
# this host; point EBS_CLIENT_LIB_DIR at its lib dir, or leave blank to use the
# default library search path.
EBS_DB_THICK=false
EBS_CLIENT_LIB_DIR=

# --- Connection pool ---
EBS_POOL_MIN=1
EBS_POOL_MAX=4
EBS_POOL_INCREMENT=1
EBS_POOL_TIMEOUT=60
EBS_QUEUE_TIMEOUT=60000

# --- Query limits ---
DEFAULT_QUERY_LIMIT=50
MAX_QUERY_LIMIT=500

# ---------------------------------------------------------------------------
# POST /invoices (Payables Open Interface Import) settings.
# Only needed if you deploy invoice creation. Confirm all of these with a DBA.
# ---------------------------------------------------------------------------
# Concurrent program: application short name + program short name.
EBS_IMPORT_PROGRAM_APP=SQLAP
EBS_IMPORT_PROGRAM_SHORT=APXIIMPT
# Source value the import filters on; must match a Payables lookup 'Source'.
EBS_IMPORT_SOURCE=MAKE_API
# apps context used to submit the concurrent request (FND_GLOBAL.APPS_INITIALIZE).
EBS_APPS_USER_ID=
EBS_APPS_RESP_ID=
EBS_APPS_RESP_APPL_ID=
