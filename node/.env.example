# ---------------------------------------------------------------------------
# EBS Invoice API Wrapper (Node) - example configuration
# Copy to .env and fill in real values. .env is gitignored; never commit it.
# ---------------------------------------------------------------------------

# --- HTTP server ---
# Bind to loopback by default; restrict exposure at the network layer.
HOST=127.0.0.1
PORT=3000
# pino log level: trace|debug|info|warn|error|fatal|silent
LOG_LEVEL=info

# --- Shared secret required on every request (X-Client-Secret header) ---
CLIENT_SECRET=change-me-to-a-long-random-string

# --- Oracle EBS database connection (oracledb Thin mode; no Instant Client) ---
EBS_DB_USER=make_ap_svc
EBS_DB_PASSWORD=change-me
# Easy Connect string: host:port/service_name
EBS_DB_CONNECT_STRING=ebs-db-host:1521/EBSPDB

# --- Connection pool ---
EBS_POOL_MIN=1
EBS_POOL_MAX=4
EBS_POOL_INCREMENT=1
EBS_POOL_TIMEOUT=60
EBS_QUEUE_TIMEOUT=60000

# --- Query limits ---
DEFAULT_QUERY_LIMIT=50
MAX_QUERY_LIMIT=500

# ---------------------------------------------------------------------------
# POST /invoices (Payables Open Interface Import) settings.
# Only needed if you deploy invoice creation. Confirm all of these with a DBA.
# ---------------------------------------------------------------------------
# Concurrent program: application short name + program short name.
EBS_IMPORT_PROGRAM_APP=SQLAP
EBS_IMPORT_PROGRAM_SHORT=APXIIMPT
# Source value the import filters on; must match a Payables lookup 'Source'.
EBS_IMPORT_SOURCE=MAKE_API
# apps context used to submit the concurrent request (FND_GLOBAL.APPS_INITIALIZE).
EBS_APPS_USER_ID=
EBS_APPS_RESP_ID=
EBS_APPS_RESP_APPL_ID=
